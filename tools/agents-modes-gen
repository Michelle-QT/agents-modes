def conformance_matrix(spec):
    """One effective-policy status per target, mode, and axis."""
    rows = []
    for target in ("claude", "codex"):
        for mode in spec["modes"]:
            target_gap_axes = {g["axis"] for g in target_gaps(spec, target, mode)}
            accepted_gap_axes = {
                g["axis"] for g in spec.get("gaps", [])
                if target in g["targets"] and mode in g["modes"]
            }
            for axis in COVERAGE_AXES:
                if axis in target_gap_axes:
                    status = "target-gap"
                elif axis in accepted_gap_axes:
                    status = "accepted-gap"
                else:
                    status = "conformant"
                rows.append({
                    "target": target,
                    "mode": mode,
                    "axis": axis,
                    "status": status,
                })
    return rows


def approval_carriers(spec):
    """The distinct command-approval carriers per target.

    Every mode in a group shares the same generated approval machinery on that target, so
    one representative witnesses the group by hand; the offline tier pins the per-mode
    fields. This is what keeps the by-hand surface small without dropping any mode.
    """
    groups = []
    for target in ("claude", "codex"):
        for auto in (True, False):
            modes = [name for name, m in spec["modes"].items()
                     if m["commands"]["sandboxed_auto"] == auto]
            if not modes:
                continue
            rep = modes[0]
            if target == "claude":
                carrier = "sandboxed-auto" if auto else "runbox-gated"
            else:
                carrier = "run-as-user-on-request" if auto else "run-as-user-untrusted"
            groups.append({"target": target, "carrier": carrier,
                           "representative": rep, "modes": sorted(modes)})
    return groups


def approval_witness_matrix(spec):
    """Manual witness rows for the prompt distinction the deterministic matrix cannot make."""
    checks = [
        ("prompt-appears", "a prompt appears before the boundary command runs"),
        ("deny-prevents-execution", "user denial prevents the boundary command from running"),
        ("accept-runs-as-user", "user acceptance runs the same boundary command as the user"),
    ]
    rows = []
    for group in approval_carriers(spec):
        case = command_boundary_case(spec, group["representative"])
        for check, expectation in checks:
            rows.append({
                "target": group["target"],
                "carrier": group["carrier"],
                "mode": group["representative"],
                "covers": group["modes"],
                "axis": "commands",
                "behavior": "outside",
                "case": case,
                "runner": "manual",
                "check": check,
                "expectation": expectation,
            })
    return rows


