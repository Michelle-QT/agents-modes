#!/usr/bin/env python3
"""Render the capability table in modes.json into per-target artifacts.

Every cell of the table is stated once, in modes.json. This turns each cell into
whatever the target's engine actually reads: a Claude settings key, a Codex profile
key. Nothing it emits is committed; `make install` generates into the share dirs.

The per-target carrier for each cell is recorded in modes.json under targets.*.carriers.
Read those before changing an emitter: several are counterintuitive and two were wrong
in the documentation this was built from.

python3 is already a runtime dependency (codex-helper-dispatch is python3 and runs on
every Codex launch), and jq cannot emit TOML, so a jq generator would have to build the
Codex profiles by shell string interpolation -- pushing the secrets list, the most
security-relevant data here, through the least safe emitter.
"""

import argparse
import json
import os
import re
import sys

BARE_KEY = re.compile(r"[A-Za-z0-9_-]+")


def die(msg):
    print(f"agents-modes-gen: {msg}", file=sys.stderr)
    raise SystemExit(1)


# ---------------------------------------------------------------- TOML emitting

def toml_string(s):
    out = ['"']
    for ch in s:
        if ch == '"':
            out.append('\\"')
        elif ch == "\\":
            out.append("\\\\")
        elif ch == "\n":
            out.append("\\n")
        elif ord(ch) < 0x20:
            out.append("\\u%04x" % ord(ch))
        else:
            out.append(ch)
    out.append('"')
    return "".join(out)


def toml_key(k):
    return k if BARE_KEY.fullmatch(k) else toml_string(k)


def toml_value(v):
    if isinstance(v, bool):
        return "true" if v else "false"
    if isinstance(v, int):
        return str(v)
    if isinstance(v, str):
        return toml_string(v)
    die(f"cannot emit TOML value: {v!r}")


def toml_array(values):
    return "[" + ", ".join(toml_string(v) for v in values) + "]"


# ---------------------------------------------------------------- shell emitting

def shell_word(s):
    return "'" + s.replace("'", "'\"'\"'") + "'"


# ------------------------------------------------------------------- the table

def load_spec(root):
    path = os.path.join(root, "modes.json")
    try:
        with open(path) as fh:
            return json.load(fh)
    except OSError as exc:
        die(f"cannot read {path}: {exc}")
    except json.JSONDecodeError as exc:
        die(f"{path} is not valid JSON: {exc}")


def load_prompt_text(root):
    path = os.path.join(root, "prompts", "text.json")
    try:
        with open(path) as fh:
            return json.load(fh)
    except OSError as exc:
        die(f"cannot read {path}: {exc}")
    except json.JSONDecodeError as exc:
        die(f"{path} is not valid JSON: {exc}")


def helper_prompt(root, helper):
    path = os.path.join(root, "prompts", "helpers", f"{helper}.md")
    try:
        with open(path) as fh:
            return fh.read().strip()
    except OSError as exc:
        die(f"cannot read helper prompt {path}: {exc}")


def mode_of(spec, name):
    if name not in spec["modes"]:
        die(f"unknown mode: {name} (have: {', '.join(sorted(spec['modes']))})")
    return spec["modes"][name]


def secret_read_rules(spec):
    """The secrets row as Read() deny rules.

    A tree needs the bare rule and the recursive one; a file needs one. `kind` is data
    because it cannot be inferred: ~/.aws is a tree and ~/.config/git/credentials is a
    file, and neither is distinguishable from its last path segment.
    """
    rules = []
    for entry in spec["secrets"]["home"]:
        rules.append(f"Read({entry['path']})")
        if entry["kind"] == "tree":
            rules.append(f"Read({entry['path']}/**)")
    rules.extend(f"Read({g})" for g in spec["secrets"]["in_tree"])
    return rules


def project_forbidden(spec):
    """Forbidden paths anchored in the project, as (bare, recursive-or-None) pairs."""
    out = []
    for group in spec["forbidden"]["groups"]:
        for p in group["paths"]:
            if p["scope"] != "project":
                continue
            out.append((p["path"], p["kind"] == "tree"))
    return out


def web_tools(spec, mode):
    """Whether the mode gets WebFetch/WebSearch.

    Derived, not declared: the web tools are one route to unrestricted egress, so a mode
    that can reach any destination gets them and a mode with named or no egress does not.
    """
    return spec["modes"][mode]["egress"]["destinations"] == "any"


def mcp_servers(spec, mode):
    return {name: spec["mcp_servers"][name] for name in mode_of(spec, mode)["mcp"]}


def codex_run_as_user(spec):
    return spec["targets"]["codex"]["run_as_user"]


def sandbox_network_open(spec, mode):
    """Whether the mode's OWN sandbox carries its egress.

    Derived, not declared: the sandbox network exists to serve sandboxed host commands,
    so it stays shut in a mode that auto-runs none. Research reaches `any` through
    runbox and the web tools instead, which is why `*` means the same thing in both
    rows while only one of them opens a sandbox.
    """
    m = spec["modes"][mode]
    return m["egress"]["destinations"] == "any" and m["commands"]["sandboxed_auto"]


def codex_approval_policy(spec, mode):
    """Codex carrier for the mode's command cell.

    Development-family modes want sandbox-confined commands to run normally and boundary
    crossings to stay interactive. Research wants most host shell commands escalated to
    the user, with only Codex's own trusted read-only command set and the generated
    runbox rule running no-ask.
    """
    m = mode_of(spec, mode)
    if not m["commands"]["sandboxed_auto"]:
        return 'approval_policy = "untrusted"'
    return 'approval_policy = "on-request"'


def codex_rule_helpers(spec):
    grants = []
    for mode, m in spec["modes"].items():
        if m["commands"]["sandboxed_auto"]:
            continue
        for helper in m["commands"]["grants"]:
            if spec["helpers"][helper].get("needs_container"):
                grants.append(helper)
    return sorted(set(grants))


def codex_rules(spec):
    """Generated command-prefix rules for Codex's explicit command carriers.

    With `untrusted`, Codex would otherwise prompt before running `runbox`, even though
    the table grants it no-ask in Research. Development-family no-ask helpers still go
    through the launcher dispatcher.
    """
    lines = [
        "# Generated from modes.json by tools/agents-modes-gen.",
        "# Narrow rule surface: only boxed helpers in non-sandboxed-auto modes.",
        "",
    ]
    for helper in codex_rule_helpers(spec):
        modes = [m["display"] for m in spec["modes"].values()
                 if helper in m["commands"]["grants"]]
        lines.extend([
            "prefix_rule(",
            f"    pattern = [{json.dumps(helper)}],",
            '    decision = "allow",',
            "    justification = "
            + json.dumps(f"{', '.join(modes)} grants {helper} as a no-ask boxed command path"),
            ")",
            "",
        ])
    return "\n".join(lines)


def target_gaps(spec, target, mode=None):
    gaps = spec["targets"].get(target, {}).get("gaps", [])
    if mode is None:
        return gaps
    return [g for g in gaps if mode in g.get("modes", [])]


def comment_line(s):
    return "# " + " ".join(str(s).split())


def container_policy_sh(spec):
    lines = [
        "# Generated from modes.json by tools/agents-modes-gen.",
        "# Sourced by container/boxlib.sh to keep runbox aligned with the table.",
        "",
        "AGENTS_BOX_SECRET_GLOBS=(",
    ]
    for glob in spec["secrets"]["in_tree"]:
        lines.append(f"  {shell_word(glob)}")
    lines.extend([
        ")",
        "",
        "AGENTS_BOX_FORBIDDEN_PROJECT_PATHS=(",
    ])
    for path, tree in project_forbidden(spec):
        kind = "tree" if tree else "file"
        lines.append(f"  {shell_word(path + ':' + kind)}")
    lines.extend([
        ")",
        "",
    ])
    return "\n".join(lines)


# ------------------------------------------------------------ Claude settings

def claude_settings(spec, mode):
    m = mode_of(spec, mode)
    tmp = spec["targets"]["claude"]["tmp_paths"]

    allow = []
    # A bare Bash allow is what makes sandboxed commands run without prompting; without
    # it even a fully sandboxed loop prompts.
    if m["commands"]["sandboxed_auto"]:
        allow.append("Bash")
    # A bare Read allow means "never prompt for Read", which widens the region to the
    # host. Its ABSENCE is what confines reads to the working directory, because the
    # built-in tools default to no-approval only within cwd + additionalDirectories.
    if m["read"]["region"] == "host":
        allow.extend(["Read", "Glob", "Grep"])
    if web_tools(spec, mode):
        allow.extend(["WebFetch", "WebSearch"])
    for server in m["mcp"]:
        allow.append(f"mcp__{server}__*")
    for helper in m["commands"]["grants"]:
        # Only a helper the agent cannot otherwise reach needs a Bash() allow rule;
        # with sandboxed_auto the bare Bash allow already covers it.
        if not m["commands"]["sandboxed_auto"]:
            allow.extend([f"Bash({helper})", f"Bash({helper} *)"])

    ask = ["Bash(dangerouslyDisableSandbox:true)"]
    for path, tree in project_forbidden(spec):
        # ask, not deny: nothing is silently auto-denied, per the table's `outside -> prompt`.
        #
        # Edit() only, never Write(). Claude Code does not match Write(path) rules against
        # file permission checks at all and says so at startup: "Write(...) is not matched
        # by file permission checks -- only Edit(path) rules are ... (Edit rules cover all
        # file-editing tools)". A Write() rule here is dead, and worse than dead: it reads
        # like a guard that does not exist.
        target = f"./{path}/**" if tree else f"./{path}"
        ask.append(f"Edit({target})")

    permissions = {"defaultMode": "acceptEdits", "allow": allow,
                   "deny": secret_read_rules(spec), "ask": ask}
    if m["write"]["plus"]:
        permissions["additionalDirectories"] = list(tmp)

    sandbox = {
        "enabled": True,
        "failIfUnavailable": True,
        "autoAllowBashIfSandboxed": m["commands"]["sandboxed_auto"],
        "allowUnsandboxedCommands": True,
        "excludedCommands": [t for h in m["commands"]["grants"] for t in (h, f"{h} *")],
    }
    if sandbox_network_open(spec, mode):
        sandbox["network"] = {"allowedDomains": ["*"]}

    fs = {}
    if m["write"]["plus"]:
        fs["allowWrite"] = list(tmp)
    deny_write = []
    for path, tree in project_forbidden(spec):
        # Project-relative; the launcher absolutizes these against $PWD at session start,
        # since a `./` path in an installed settings file has no project to anchor to.
        deny_write.append(f"./{path}")
        if tree:
            deny_write.append(f"./{path}/**")
    for group in spec["forbidden"]["groups"]:
        for p in group["paths"]:
            if p["scope"] != "home":
                continue
            deny_write.append(p["path"])
            if p["kind"] == "tree":
                deny_write.append(f"{p['path']}/**")
    fs["denyWrite"] = deny_write
    # Every axis has two surfaces: the native one (permission rules, which govern the
    # built-in tools) and the sandboxed one (sandbox.*, which governs Bash). They must be
    # confined together or the cell is only half delivered -- which is exactly how the
    # secrets row came to protect `cat` and not `Read`.
    #
    # read, sandboxed leg. `region: workdir` means the built-in tools are confined by the
    # ABSENCE of a bare Read allow; the sandbox needs saying explicitly, because deny-only
    # leaves it reading the whole host. Literal workdir confinement is not implementable:
    # a sandboxed command must read /bin/sh to run and /etc/ssl/cert.pem to do TLS, so
    # denyRead "/" would break every command. Deny the home tree instead, which is where
    # the user's data is, and re-allow the project -- the docs' own worked example.
    if m["read"]["region"] == "workdir":
        fs["denyRead"] = ["~/"] + [e["path"] for e in spec["secrets"]["home"]]
        fs["allowRead"] = ["./"]
    else:
        fs["denyRead"] = [e["path"] for e in spec["secrets"]["home"]]
    sandbox["filesystem"] = fs

    return {"env": {"AGENTS_CLAUDE_MODE": m["slug"]}, "permissions": permissions,
            "sandbox": sandbox}


def claude_mcp_config(spec, mode):
    servers = {}
    for name, config in mcp_servers(spec, mode).items():
        servers[name] = {
            "command": config["command"],
            "args": list(config.get("args", [])),
        }
    return {"mcpServers": servers}


# ------------------------------------------------------------- Codex profile

def codex_profile(spec, mode, tui_fragment):
    m = mode_of(spec, mode)
    name = f"agents-{mode}"
    lines = [
        "# Generated from modes.json by tools/agents-modes-gen.",
    ]
    gaps = target_gaps(spec, "codex", mode)
    if gaps:
        lines.append("# Target gaps for this profile are explicit here because the desired table is stricter than Codex can currently express.")
        for gap in gaps:
            lines.append(comment_line(
                f"Target gap ({gap['axis']}): {gap['status']}. Desired: {gap['desired']}. Actual: {gap['actual']}."
            ))
    lines += [
        codex_approval_policy(spec, mode),
        f'default_permissions = "{name}"',
        f'web_search = "{"live" if web_tools(spec, mode) else "disabled"}"',
        "",
        f"[permissions.{name}.filesystem]",
        "glob_scan_max_depth = 4",
    ]
    lines.append(f'":root" = "read"' if m["read"]["region"] == "host"
                 else f'":minimal" = "read"')
    if m["write"]["plus"]:
        lines += ['":tmpdir" = "write"', '":slash_tmp" = "write"',
                  '"/private/tmp" = "write"']
    for entry in spec["secrets"]["home"]:
        lines.append(f'{toml_string(entry["path"])} = "deny"')
    # In-tree patterns are NOT emitted here. The top-level table is host-wide, and a
    # host-wide "/**/*.pem" denies /etc/ssl/cert.pem -- the system CA bundle -- which
    # breaks TLS for every sandboxed command. Found by the agent tier: curl failed with
    # "error setting certificate verify locations". They are called in-tree because that
    # is what they are: a private key in the project, not the OS trust store. They go in
    # the workspace table below.
    #
    # Home-scoped forbidden paths get NO entry here either. Codex only makes the
    # workspace writable, so a home path is already unwritable; "deny" would be wrong
    # (forbidden is readable), and "read" would be worse still -- under Research's
    # ":minimal" it would GRANT read access the mode otherwise does not have.

    lines += ["", f'[permissions.{name}.filesystem.":workspace_roots"]', '"." = "write"']
    for glob in spec["secrets"]["in_tree"]:
        lines.append(f'{toml_string(glob)} = "deny"')
    if m["write"]["region"] == "workdir":
        # Codex's default sandbox makes .git read-only, so re-grant it for local
        # commits, then re-deny config and hooks. Verified: Codex resolves
        # most-specific-wins even specific-vs-specific.
        lines += ['".git" = "write"', '".git/**" = "write"']
    for path, tree in project_forbidden(spec):
        lines.append(f'{toml_string(path)} = "read"')
        if tree:
            lines.append(f'{toml_string(path + "/**")} = "read"')

    lines += ["", f"[permissions.{name}.network]",
              f"enabled = {'true' if sandbox_network_open(spec, mode) else 'false'}"]
    out = "\n".join(lines) + "\n"
    return out + tui_fragment


def codex_session_config(spec, mode):
    run_as_user = codex_run_as_user(spec)
    lines = [
        "# Generated from modes.json by tools/agents-modes-gen.",
        "# Applied as mode-owned overrides over the incoming user config.",
        "",
        "[apps._default]",
        "enabled = false",
        "destructive_enabled = false",
        "open_world_enabled = false",
        "",
        "[features]",
        "apps = false",
        "browser_use = false",
        "browser_use_full_cdp_access = false",
        "browser_use_external = false",
        "computer_use = false",
        "exec_permission_approvals = false",
        "hooks = false",
        "image_generation = false",
        "in_app_browser = false",
        "plugin_sharing = false",
        "plugins = false",
        "remote_plugin = false",
        "",
        f"[mcp_servers.{toml_key(run_as_user['server'])}]",
        f"command = {toml_string(run_as_user['executable'])}",
        'args = ["__AGENTS_RUN_AS_USER_ENVIRONMENT__"]',
        "enabled = true",
        "required = true",
        f"default_tools_approval_mode = {toml_string(run_as_user['approval_mode'])}",
        "",
        f"[mcp_servers.{toml_key(run_as_user['server'])}.tools.{toml_key(run_as_user['tool'])}]",
        f"approval_mode = {toml_string(run_as_user['approval_mode'])}",
    ]
    for name, config in mcp_servers(spec, mode).items():
        lines.extend([
            "",
            f"[mcp_servers.{toml_key(name)}]",
            f"command = {toml_string(config['command'])}",
            f"args = {toml_array(config.get('args', []))}",
            "enabled = true",
            "required = true",
            'default_tools_approval_mode = "approve"',
        ])
    return "\n".join(lines) + "\n"


# ------------------------------------------------------------- README blocks

def _read_cell(m):
    return f'`{m["read"]["region"]} \u2212 secrets`'


def _write_cell(m):
    w = m["write"]
    cell = "`" + w["region"] + "".join(f' \u2212 {x}' for x in w["minus"]) + "`"
    for extra in w["plus"]:
        cell += f", `{extra}`"
    return cell


def _egress_cell(m):
    d = m["egress"]["destinations"]
    if d == "any":
        return "`*`"
    if d == "none":
        return "off"
    return "off, plus " + ", ".join(f"`{h}`" for h in m["egress"]["via"])


def _commands_cell(spec, m):
    parts = []
    if m["commands"]["sandboxed_auto"]:
        parts.append("sandboxed auto")
    escapes = [h for h in m["commands"]["grants"]
               if not spec["helpers"][h].get("needs_container")]
    boxed = [h for h in m["commands"]["grants"]
             if spec["helpers"][h].get("needs_container")]
    for h in boxed:
        parts.append(f"`{h}` auto")
    if escapes:
        parts.append("escapes auto, unsandboxed")
    elif not boxed:
        parts.append("no escapes")
    if not escapes and boxed:
        parts.append("no escapes")
    parts.append(f'outside \u2192 {m["commands"]["outside"]}')
    return "; ".join(parts)


def prompt_text(root, spec, target, mode):
    if target not in spec["targets"]:
        die(f"unknown target: {target} (have: {', '.join(sorted(spec['targets']))})")
    m = mode_of(spec, mode)
    display = m["display"]
    text = load_prompt_text(root)
    # The three-outcome contract is data (command_outcomes), not a hand-written sentence,
    # so the prompt cannot drift from the contract the matrices are derived from.
    oc = spec["command_outcomes"]
    lines = [
        text["title"].format(display=display),
        "",
        text["current_mode"].format(display=display),
        "",
        text["command_outcomes"].format(**oc),
        "",
    ]
    if target == "codex":
        lines[2] += text["codex_collaboration_suffix"]

    read_region = text["read_regions"][m["read"]["region"]]
    write_region = text["write_regions"]["workdir_plus" if m["write"]["plus"] else "workdir"]
    lines.extend([
        text["access"].format(read_region=read_region, write_region=write_region),
        "",
    ])

    dest = m["egress"]["destinations"]
    if dest == "any":
        if m["commands"]["sandboxed_auto"]:
            lines.extend([
                text["network"]["any_sandboxed"],
                "",
            ])
        else:
            lines.extend([
                text["network"]["any_boxed"],
                "",
            ])
    elif dest == "named":
        helpers = ", ".join(f"`{h}`" for h in m["egress"]["via"])
        lines.extend([
            text["network"]["named"].format(helpers=helpers),
            "",
        ])
    else:
        lines.extend([
            text["network"]["none"],
            "",
        ])

    if target == "codex":
        if m["mcp"]:
            servers = ", ".join(server.title() for server in m["mcp"])
            lines.extend([
                text["mcp"]["codex_granted"].format(servers=servers),
                "",
            ])
        else:
            lines.extend([
                text["mcp"]["codex_none"],
                "",
            ])
    elif m["mcp"]:
        servers = ", ".join(server.title() for server in m["mcp"])
        lines.extend([
            text["mcp"]["claude_granted"].format(servers=servers),
            "",
        ])
    else:
        lines.extend([
            text["mcp"]["claude_none"],
            "",
        ])
    if target == "claude":
        lines.extend(text["integrations"]["claude"])
    else:
        lines.extend(text["integrations"]["codex"])
    lines.extend([
        text["integrations"]["authority"],
        "",
    ])

    grants = m["commands"]["grants"]
    for helper in grants:
        lines.extend([helper_prompt(root, helper), ""])

    if grants:
        lines.extend([
            text["helper_standalone"],
            "",
        ])

    auto_items = []
    if m["commands"]["sandboxed_auto"]:
        auto_items.append(text["automatic_item"]["sandboxed"])
    for helper in grants:
        auto_items.append(text["automatic_item"]["helper"].format(helper=helper))
    if web_tools(spec, mode):
        auto_items.append(text["automatic_item"]["web"])
    if m["mcp"]:
        auto_items.append(text["automatic_item"]["mcp"])
    if not auto_items:
        auto_items.append(text["automatic_item"]["fallback"])

    gated_items = [text["prompt_item"]["outside"]]
    if grants:
        gated_items.append(text["prompt_item"]["compound_helper"])
    gated_items.append(text["prompt_item"]["policy_write"])

    lines.extend([
        text["rules"]["automatic"].format(items=", ".join(auto_items)),
        text["rules"]["prompt"].format(items=", ".join(gated_items)),
        text["rules"]["forbidden"],
        "",
        text["boundary"]["common"],
    ])
    if target == "codex":
        lines.extend([
            text["boundary"]["codex_route"],
            text["boundary"]["codex_denial"],
        ])
    else:
        lines.append(text["boundary"]["claude_denial"])
    gaps = target_gaps(spec, target, mode)
    if gaps:
        lines.extend(["", text["gaps"]["heading"]])
        for gap in gaps:
            lines.append(text["gaps"]["item"].format(axis=gap["axis"], status=gap["status"]))
    return "\n".join(lines) + "\n"


def readme_table(spec):
    lines = ["| Mode | read | write | egress | mcp | commands |",
             "| --- | --- | --- | --- | --- | --- |"]
    for m in spec["modes"].values():
        lines.append("| " + " | ".join([
            m["display"], _read_cell(m), _write_cell(m), _egress_cell(m),
            ", ".join(m["mcp"]) if m["mcp"] else "none",
            _commands_cell(spec, m),
        ]) + " |")
    return "\n".join(lines) + "\n"


def readme_secrets(spec):
    s = spec["secrets"]
    home = ", ".join(f'`{e["path"]}`' for e in s["home"])
    in_tree = ", ".join(f"`{g}`" for g in s["in_tree"])
    return (f'- `secrets`: {s["why"]}.\n\t- {home}\n'
            f'\t- {in_tree}: anchored at the launched project, not host-wide, since a host-wide pattern would deny the OS trust store (`/etc/ssl/cert.pem`) and break TLS.\n')


def readme_forbidden(spec):
    f = spec["forbidden"]
    out = [f'- `forbidden`: {f["why"]}.']
    for group in f["groups"]:
        paths = ", ".join(
            "`" + ("**/" if p["scope"] == "project" else "")
            + p["path"] + ("/**" if p["kind"] == "tree" else "") + "`"
            for p in group["paths"])
        out.append(f'\t- {paths}: {group["why"]}.')
    return "\n".join(out) + "\n"


def readme_integrations(spec):
    p = spec["integration_policy"]
    surfaces = ", ".join(f"`{surface}`" for surface in p["surfaces"])
    return (f'- `integrations`: {p["why"]}.\n'
            f'\t- Default: `{p["default"]}` for {surfaces}.\n'
            f'\t- Caveat: {p["caveat"]}.\n'
            f'\t- {p["authority"]}.\n'
            f'\t- {p["trusted_inputs"]}.\n')


def _human_list(values):
    if len(values) == 1:
        return values[0]
    if len(values) == 2:
        return f"{values[0]} and {values[1]}"
    return ", ".join(values[:-1]) + f", and {values[-1]}"


def readme_gaps(spec):
    records = [(gap, gap["targets"]) for gap in spec.get("gaps", [])]
    for target, target_spec in spec["targets"].items():
        records.extend((gap, [target]) for gap in target_spec.get("gaps", []))
    lines = []
    for gap, targets in records:
        target_names = _human_list([target.title() for target in targets])
        mode_names = _human_list([mode_of(spec, mode)["display"] for mode in gap["modes"]])
        lines.append(
            f'- **{gap["status"]}** (`{gap["axis"]}`; {target_names}; {mode_names}): '
            f'{gap["actual"]}; desired: {gap["desired"]}.'
        )
    return "\n".join(lines) + "\n"


README_BLOCKS = {"table": readme_table, "secrets": readme_secrets,
                 "forbidden": readme_forbidden, "integrations": readme_integrations,
                 "gaps": readme_gaps}


def readme_extract(name, path):
    """Pull a marked block out of README, so the check has something to compare."""
    try:
        text = open(path).read()
    except OSError as exc:
        die(f"cannot read {path}: {exc}")
    begin, end = f"<!-- agents-modes:begin {name} -->", f"<!-- agents-modes:end {name} -->"
    if begin not in text or end not in text:
        die(f"{path} has no markers for block: {name}")
    body = text.split(begin, 1)[1].split(end, 1)[0]
    # strip(), not strip("\n"): a formatter may leave a whitespace-only line against a
    # marker, and that is padding rather than content.
    return body.strip() + "\n"


# ------------------------------------------------------------------ manifest

def manifest(spec, mode):
    """What a launcher needs at runtime, and nothing else.

    Only the helper grant: the launcher's job is to build the shim dir. The rest of the
    table is already delivered through the settings file and the profile, and prose
    belongs in modes.json rather than shipped into a runtime artifact.
    """
    m = mode_of(spec, mode)
    grants = list(m["commands"]["grants"])
    shims = sorted(set(grants) | set(codex_rule_helpers(spec)))
    needs_container = any(spec["helpers"][helper].get("needs_container", False)
                          for helper in grants)
    return {
        "slug": m["slug"],
        "display": m["display"],
        "grants": grants,
        "shims": shims,
        "needs_container": needs_container,
        "codex_run_as_user": {
            "executable": codex_run_as_user(spec)["executable"],
        },
    }


def runtime_helper_list(spec):
    return " ".join(helper["source"] for helper in spec["helpers"].values()) + "\n"


def codex_run_as_user_source(spec):
    return codex_run_as_user(spec)["source"] + "\n"


