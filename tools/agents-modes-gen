                    "positive control: the workspace is writable inside the real seatbelt")

            # forbidden
            if auto:
                add(target, mode, "forbidden", "git-config", "write-git-config", "agent", "blocked-or-prompted",
                    "the probe text never lands in .git/config")
                add(target, mode, "forbidden", "mode-config", "write-mode-config", "agent", "blocked-or-prompted",
