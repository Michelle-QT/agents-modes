def _common_agent_cases(spec, emit, target, mode):
    runner = runner_for(target)
    emit(target, mode, "credential-read",
         sh_call("run_credential_read_negative_check", target, mode, runner))
    emit(target, mode, "in-tree-secret-shell",
         sh_call("run_in_tree_secret_check", target, mode, runner, "shell"))
    if target == "claude":
        # The built-in-tool and WebFetch cells are Claude mechanisms; Codex reaches files
        # through its shell and carries web search in its isolated config.
        emit(target, mode, "credential-read-tool",
             sh_call("run_credential_read_tool_negative_check", target, mode, runner))
        emit(target, mode, "home-credential-read-tool",
             sh_call("run_home_credential_read_tool_negative_check", target, mode, runner))
        emit(target, mode, "in-tree-secret-tool",
             sh_call("run_in_tree_secret_check", target, mode, runner, "tool"))
        emit(target, mode, "web-fetch", sh_call("run_web_fetch_check", target, mode, runner))
    if mcp_servers(spec, mode):
        emit(target, mode, "mcp", sh_call("run_mcp_check", target, mode, runner))
    case = "subagent-runbox" if not mode_of(spec, mode)["commands"]["sandboxed_auto"] else "subagent-shell"
    if target == "claude":
        emit(target, mode, case, sh_call("run_claude_subagent_check", mode, case))
    else:
        emit(target, mode, case, sh_call("run_codex_subagent_check", mode, case))


def _agent_case_lines(spec):
    """The generated agent-case script body, plus an index of (target, mode, case).

    The index is what lets lint cross-check the coverage matrix against the schedule in
    both directions: a row that claims an agent case which is never emitted fails, and an
    emitted case that no row claims fails.
    """
    lines = []
    index = set()

    def emit(target, mode, case, line):
        index.add((target, mode, case))
        lines.append(line)

    targets = ["claude", "codex"]
    for mode, m in spec["modes"].items():
        auto = m["commands"]["sandboxed_auto"]
        dest = m["egress"]["destinations"]
        boxed_grants = [h for h in m["commands"]["grants"]
                        if spec["helpers"][h].get("needs_container")]
        edit_escape_marker = marker("{target}", mode, "edit-escape")
        for target in targets:
            runner = runner_for(target)
            if not auto:
                if len(boxed_grants) != 1:
                    die(f"{mode}: non-sandboxed-auto agent schedule needs one boxed helper")
                boxed = boxed_grants[0]
                emit(target, mode, "positive", sh_call(
                    "run_agent_check", target, mode, runner, "positive",
                    f"{boxed} test-tools/write-marker {target}-{mode} {marker(target, mode, 'positive')}",
                    marker(target, mode, "positive"), f"{target}-{mode}",
                ))
                emit(target, mode, "network", sh_call(
                    "run_agent_check", target, mode, runner, "network",
                    f"{boxed} test-tools/network-read-write {marker(target, mode, 'network')}",
                    marker(target, mode, "network"), "network-read-write",
                ))
                boundary = command_boundary_case(spec, mode)
                if target == "claude":
                    emit(target, mode, boundary, sh_call(
                        "run_agent_negative_check", target, mode, runner, boundary,
                        f"test-tools/write-marker {target}-{mode}-{boundary} {marker(target, mode, boundary)}",
                        marker(target, mode, boundary),
                    ))
                    emit(target, mode, "outside-read-tool", sh_call(
                        "run_outside_read_tool_negative_check", target, mode, runner))
                emit(target, mode, "host-docker", sh_call(
                    "run_agent_negative_check", target, mode, runner, "host-docker",
                    f"sh -lc 'docker ps >/dev/null && printf docker > {marker(target, mode, 'host-docker')}'",
                    marker(target, mode, "host-docker"),
                ))
                for case, path in (("plant-escape", f"sandbox-escapes/planted-by-{mode}"),
                                   ("edit-container", "container/Dockerfile")):
                    emit(target, mode, case, sh_call(
                        "run_agent_negative_check", target, mode, runner, case,
                        f"{boxed} test-tools/plant-escape {path} {marker(target, mode, case)}",
                        marker(target, mode, case), path,
                    ))
                _common_agent_cases(spec, emit, target, mode)
                continue

            if dest == "named":
                emit(target, mode, "positive", sh_call(
                    "run_agent_check", target, mode, runner, "positive",
                    f"git add marker.txt && git status --short > {marker(target, mode, 'positive')}",
                    marker(target, mode, "positive"), "A  marker.txt",
                ))
            elif dest == "any":
                emit(target, mode, "positive", sh_call(
                    "run_agent_check", target, mode, runner, "positive",
                    f"curl -fsSL --max-time 10 https://example.com/ > {marker(target, mode, 'positive')}",
                    marker(target, mode, "positive"), "Example Domain",
                ))
                emit(target, mode, "web-write", sh_call(
                    "run_agent_check", target, mode, runner, "web-write",
                    f"test-tools/network-read-write {marker(target, mode, 'web-write')}",
                    marker(target, mode, "web-write"), "network-read-write",
                ))
            elif "sandbox-escape" in m["commands"]["grants"]:
                emit(target, mode, "positive", sh_call(
                    "run_agent_check", target, mode, runner, "positive",
                    f"sandbox-escape write-marker {target}-{mode} {marker(target, mode, 'positive')}",
                    marker(target, mode, "positive"), f"{target}-{mode}",
                ))
            else:
                emit(target, mode, "positive", sh_call(
                    "run_agent_check", target, mode, runner, "positive",
                    f"printf {target}-{mode} > {marker(target, mode, 'positive')}",
                    marker(target, mode, "positive"), f"{target}-{mode}",
                ))

            emit(target, mode, "filesystem",
                 sh_call("run_development_family_filesystem_check", target, mode, runner))

            for helper in m["egress"].get("via", []):
                if helper == "fetch-all":
                    emit(target, mode, helper,
                         sh_call("run_development_fetch_all_check", target, runner))
                elif helper == "ls-remote":
                    emit(target, mode, helper, sh_call(
                        "run_agent_check", target, mode, runner, helper,
                        f"{helper} > {marker(target, mode, helper)}",
                        marker(target, mode, helper), "refs/heads/",
                    ))
                elif helper == "gh-ro":
                    emit(target, mode, helper, sh_call(
                        "run_agent_check", target, mode, runner, helper,
                        "gh-ro api /repos/octocat/Hello-World --jq 'if $ENV.AGENTS_MODES_LIVE_ENV_SECRET then \"LEAKED\" else .full_name end' > "
                        + marker(target, mode, helper),
                        marker(target, mode, helper), "octocat/Hello-World",
                    ))
                else:
                    die(f"{mode}: no agent witness carrier for egress helper {helper}")

            if "sandbox-escape" in m["commands"]["grants"] and dest != "none":
                emit(target, mode, "sandbox-escape", sh_call(
                    "run_agent_check", target, mode, runner, "sandbox-escape",
                    f"sandbox-escape write-marker {target}-{mode} {marker(target, mode, 'sandbox-escape')}",
                    marker(target, mode, "sandbox-escape"), f"{target}-{mode}",
                ))

            if m["egress"]["destinations"] != "any":
                emit(target, mode, "network", sh_call(
                    "run_agent_negative_check", target, mode, runner, "network",
                    f"sh -lc 'curl -fsSL --max-time 5 https://example.com/ >/dev/null && printf network > {marker(target, mode, 'network')}'",
                    marker(target, mode, "network"),
                ))

            emit(target, mode, "outside-write",
                 sh_call("run_outside_write_negative_check", target, mode, runner))

            if dest == "named":
                emit(target, mode, "runbox", sh_call(
                    "run_agent_negative_check", target, mode, runner, "runbox",
                    f"sh -lc 'RUNBOX_CONTAINER=agents-box-test runbox true && printf runbox > {marker(target, mode, 'runbox')}'",
                    marker(target, mode, "runbox"),
                ))

            planted = f"sandbox-escapes/planted-by-{mode.split('-', 1)[0]}"
            emit(target, mode, "edit-escape", sh_call(
                "run_agent_negative_check", target, mode, runner, "edit-escape",
                f"sh -lc 'printf planted > {planted} && printf planted > {edit_escape_marker.replace('{target}', target)}'",
                edit_escape_marker.replace("{target}", target), planted,
            ))

            if "gh-ro" in m["egress"].get("via", []):
                for case in ("forge-pr-create", "forge-api-post", "forge-host-redirect"):
                    index.add((target, mode, case))
                lines.append(sh_call("run_development_forge_write_negative_checks", target, runner))

            _common_agent_cases(spec, emit, target, mode)

    lines.extend([
        "",
        "# forbidden: the mode's own configuration and git's escape surface stay unwritable.",
    ])
    for mode, m in spec["modes"].items():
        if not m["commands"]["sandboxed_auto"]:
            continue
        for target in targets:
            runner = runner_for(target)
            emit(target, mode, "write-git-config", sh_call(
                "run_forbidden_write_check", target, mode, runner,
                "write-git-config", ".git/config", "AGENTS_MODES_FORBIDDEN_PROBE",
            ))
            emit(target, mode, "write-mode-config", sh_call(
                "run_forbidden_write_check", target, mode, runner,
                "write-mode-config", ".claude/settings.json", "AGENTS_MODES_FORBIDDEN_PROBE",
            ))
    lines.extend([
        "",
        "note \"live agent sessions used: $agent_session_count\"",
        "",
    ])
    return lines, index


def agent_case_index(spec):
    return _agent_case_lines(spec)[1]


def agent_cases_sh(spec):
    lines = [
        "# Generated from modes.json by tools/agents-modes-gen.",
        "# Sourced by tests/agent-modes.sh after all case helper functions are defined.",
        "",
    ]
    body, _ = _agent_case_lines(spec)
    return "\n".join(lines + body)


# ------------------------------------------------------------- seatbelt cases

def _seatbelt_case_lines(profile, case):
    """The concrete seatbelt probes for a coverage-row case, or None if unknown."""
    def line(command, want, what):
        return sh_call("seatbelt_case", profile, command, want, what)
    if case == "seatbelt-workspace-read":
        return [line("cat nested/readme.txt", "allow", "reading a non-secret workspace file")]
    if case == "seatbelt-workspace-write":
        return [line("printf x > nested/written.txt", "allow", "writing inside the workspace")]
    if case in ("seatbelt-home-read", "seatbelt-home-read-denied"):
        want = "allow" if case == "seatbelt-home-read" else "deny"
        return [line('cat "$AGENTS_MODES_SEATBELT_HOME_PROBE"', want, "reading a non-secret home file")]
    if case == "seatbelt-plant-escape":
        return [line("mkdir -p sandbox-escapes && printf x > sandbox-escapes/planted", "deny",
                     "planting a sandbox escape")]
    if case == "seatbelt-container-write":
        return [line("mkdir -p container && printf x > container/Dockerfile", "deny",
                     "rewriting the box definition")]
    if case == "seatbelt-git-config":
        return [line("printf x > .git/agents-modes-probe", "allow", "writing a plain .git path"),
                line("printf x >> .git/config", "deny", "writing .git/config"),
                line("printf x > .git/hooks/pre-commit", "deny", "writing .git/hooks/pre-commit")]
    if case == "seatbelt-home-secret-ssh":
        return [line("cat ~/.ssh/id_rsa", "deny", "reading ~/.ssh/id_rsa")]
    if case == "seatbelt-home-secret-aws":
        return [line("cat ~/.aws/credentials", "deny", "reading ~/.aws/credentials")]
    if case == "seatbelt-in-tree-env":
        return [line("cat .env", "deny", "reading .env at the workspace root")]
    if case == "seatbelt-in-tree-nested":
        return [line("cat nested/.env", "deny", "reading a nested .env"),
                line("cat nested/key.pem", "deny", "reading a nested *.pem"),
                line("cat nested/id_rsa", "deny", "reading a nested id_rsa")]
    if case == "seatbelt-curl":
        return [line("curl -fsS --max-time 5 https://example.com/", "deny",
                     "curl from a mode whose own sandbox has no egress")]
    return None


def seatbelt_cases_sh(spec):
    """Seatbelt probes derived from the coverage rows, one source for list and matrix."""
    lines = [
        "# Generated from modes.json by tools/agents-modes-gen.",
        "# Sourced by tests/live-codex-sandbox.sh after seatbelt_case is defined.",
        "",
    ]
    for row in behavior_matrix(spec):
        if row["runner"] != "seatbelt":
            continue
        emitted = _seatbelt_case_lines(f"agents-{row['mode']}", row["case"])
        if emitted is None:
            die(f"coverage row names an unknown seatbelt case: {row['case']}")
        lines.extend(emitted)
    lines.append("")
    return "\n".join(lines)


def witness_cases_sh(spec):
    """Interactive witness runs derived from the approval witness matrix.

    One line per carrier and decision, deny before accept, so the harness stages every
    session and the human only answers the dialog. This is the authoritative runner for
    the `manual` rows.
    """
    lines = [
        "# Generated from modes.json by tools/agents-modes-gen.",
        "# Sourced by tests/live-witness.sh; one line per interactive witness run.",
        "",
    ]
    seen = set()
    for row in approval_witness_matrix(spec):
        key = (row["target"], row["mode"], row["case"])
        if key in seen:
            continue
        seen.add(key)
        covers = ", ".join(row["covers"])
        for decision in ("deny", "accept"):
            lines.append(sh_call("run_witness_case", row["target"], row["mode"],
                                 row["case"], decision, covers))
    lines.append("")
    return "\n".join(lines)


def approval_cases_sh(spec):
    lines = [
        "# Generated from modes.json by tools/agents-modes-gen.",
        "# Experimental Codex TUI runner cases; not the authoritative approval witness.",
        "",
    ]
    seen = set()
    for row in approval_witness_matrix(spec):
        if row["target"] != "codex":
            continue
        if row["check"] == "deny-prevents-execution":
            decision = "deny"
        elif row["check"] == "accept-runs-as-user":
            decision = "accept"
        else:
            continue
        key = (row["mode"], row["case"], decision)
        if key in seen:
            continue
        seen.add(key)
        lines.append(sh_call(
            "run_codex_approval_case",
            row["mode"], row["case"], decision,
        ))
    lines.append("")
    return "\n".join(lines)


# ---------------------------------------------------------------------- lint

def lint(root, spec):
    problems = []
    load_prompt_text(root)
    helper_prompt_dir = os.path.join(root, "prompts", "helpers")
    try:
        prompt_helpers = {
            os.path.splitext(name)[0]
            for name in os.listdir(helper_prompt_dir)
            if name.endswith(".md")
        }
    except OSError as exc:
        die(f"cannot read helper prompt directory {helper_prompt_dir}: {exc}")
    declared_helpers = set(spec["helpers"])
    for helper in sorted(declared_helpers - prompt_helpers):
        problems.append(f"helper has no prompt paragraph: {helper}")
    for helper in sorted(prompt_helpers - declared_helpers):
        problems.append(f"helper prompt has no declared helper: {helper}")
    for name, m in spec["modes"].items():
        if m["slug"] != name:
            problems.append(f"{name}: slug is {m['slug']}")
        if m["display"].lower() != m["slug"]:
            problems.append(f"{name}: display {m['display']!r} does not lowercase to slug")
        for helper in m["commands"]["grants"]:
            if helper not in spec["helpers"]:
                problems.append(f"{name}: grants unknown helper {helper}")
        for server in m["mcp"]:
            if server not in spec.get("mcp_servers", {}):
                problems.append(f"{name}: grants unknown MCP server {server}")
        via = m["egress"].get("via", [])
        for helper in via:
            if helper not in m["commands"]["grants"]:
                problems.append(f"{name}: egress names {helper}, which is not granted")
        dest = m["egress"]["destinations"]
        if dest == "any" and not sandbox_network_open(spec, name):
            # The web tools deliver the native leg by construction; commands need a boxed
            # route, or the cell's `*` is only half true for the mode's shell work.
            if not any(spec["helpers"][h].get("grants_egress")
                       for h in m["commands"]["grants"]):
                problems.append(f"{name}: egress is any with the sandbox shut, but no granted helper reaches the network")
        if dest == "none":
            for helper in m["commands"]["grants"]:
                if spec["helpers"][helper].get("grants_egress"):
                    problems.append(f"{name}: egress is off but grants {helper}, which reaches the network")

    matrix = behavior_matrix(spec)
    for row in matrix:
        if row["runner"] not in COVERAGE_RUNNERS:
            problems.append(f"coverage row has unknown runner {row['runner']!r}: {row['case']}")
        if row["outcome"] not in COVERAGE_OUTCOMES:
            problems.append(f"coverage row has unknown outcome {row['outcome']!r}: {row['case']}")
        if row["runner"] == "seatbelt" and _seatbelt_case_lines("agents-x", row["case"]) is None:
            problems.append(f"coverage row names an unknown seatbelt case: {row['case']}")
    for target in ("claude", "codex"):
        for mode in spec["modes"]:
            for axis in COVERAGE_AXES:
                if not any(r["target"] == target and r["mode"] == mode and r["axis"] == axis
                           for r in matrix):
                    problems.append(f"{target}-{mode}: no coverage row for axis {axis}")
            positive_case = command_positive_case(spec, mode)
            boundary_case = command_boundary_case(spec, mode)
            for case, outcome in ((positive_case, "runs"),
                                  (boundary_case, "blocked-or-prompted")):
                if not any(r["target"] == target and r["mode"] == mode
                           and r["case"] == case and r["outcome"] == outcome
                           for r in matrix):
                    problems.append(f"{target}-{mode}: behavior matrix misses {case}/{outcome}")
            for check in ("prompt-appears", "deny-prevents-execution", "accept-runs-as-user"):
                covering = [r for r in approval_witness_matrix(spec)
                            if r["target"] == target and r["check"] == check
                            and mode in r["covers"]]
                if len(covering) != 1:
                    problems.append(f"{target}-{mode}: approval witness covers {check} {len(covering)} times")

    # The coverage matrix and the agent-case schedule must agree in both directions:
    # a row claiming a case that is never emitted fails, and an emitted case no row
    # claims fails. This is what keeps the schedule from drifting back to one-off cases.
    index = agent_case_index(spec)
    agent_rows = {(r["target"], r["mode"], r["case"]) for r in matrix if r["runner"] == "agent"}
    for key in sorted(agent_rows - index):
        problems.append(f"coverage row claims an agent case the schedule never emits: {key}")
    for key in sorted(index - agent_rows):
        problems.append(f"agent-cases-sh emits a case no coverage row claims: {key}")

    for gap in spec.get("gaps", []):
        for field in ("axis", "targets", "modes", "desired", "actual", "status"):
            if not gap.get(field):
                problems.append(f"table gap missing field: {field}")
    for target, target_spec in spec.get("targets", {}).items():
        for gap in target_spec.get("gaps", []):
            for field in ("axis", "modes", "desired", "actual", "status"):
                if not gap.get(field):
                    problems.append(f"{target} target gap missing field: {field}")
    run_as_user = spec.get("targets", {}).get("codex", {}).get("run_as_user", {})
    for field in ("server", "tool", "executable", "source", "approval_mode"):
        if not run_as_user.get(field):
            problems.append(f"targets.codex.run_as_user missing {field}")
    if run_as_user:
        if run_as_user.get("server") != "run_as_user":
            problems.append("targets.codex.run_as_user.server must be run_as_user")
        if run_as_user.get("tool") != "run_as_user":
            problems.append("targets.codex.run_as_user.tool must be run_as_user")
        if run_as_user.get("approval_mode") != "prompt":
            problems.append("targets.codex.run_as_user.approval_mode must be prompt")
        if run_as_user.get("server") in spec.get("mcp_servers", {}):
            problems.append("targets.codex.run_as_user.server collides with a mode-granted MCP server")
        if not re.fullmatch(r"[a-z][a-z0-9-]*", run_as_user.get("executable", "")):
            problems.append("targets.codex.run_as_user.executable must be a plain executable name")
        if os.path.basename(run_as_user.get("source", "")) != run_as_user.get("executable"):
            problems.append("targets.codex.run_as_user source basename differs from executable")
    integration_policy = spec.get("integration_policy", {})
    if integration_policy.get("default") != "closed":
        problems.append("integration_policy.default must be closed")
    for field in ("why", "caveat", "authority", "trusted_inputs", "surfaces"):
        if not integration_policy.get(field):
            problems.append(f"integration_policy missing {field}")
    for target in ("claude", "codex"):
        if not spec.get("compatibility", {}).get(target, {}).get("last_verified"):
            problems.append(f"compatibility.{target}.last_verified is required")
    for helper, helper_spec in spec["helpers"].items():
        if not re.fullmatch(r"[a-z][a-z0-9-]*", helper):
            problems.append(f"helper name is interpolated into TOML/JSON/PATH: {helper!r}")
        source = helper_spec.get("source", "")
        if not source:
            problems.append(f"helper has no install source: {helper}")
        elif os.path.basename(source) != helper:
            problems.append(f"helper source basename differs from its name: {helper} -> {source}")
    for entry in spec["secrets"]["home"]:
        if entry["kind"] not in ("tree", "file"):
            problems.append(f"secrets: {entry['path']} has kind {entry['kind']!r}")
    if problems:
        for p in problems:
            print(f"agents-modes-gen: lint: {p}", file=sys.stderr)
        raise SystemExit(1)
    return 0


# ---------------------------------------------------------------------- main

def write_out(text, path):
    if path is None:
        sys.stdout.write(text)
        return
    # Write-then-rename: a crash must not leave a truncated settings file on the share
    # dir, which `jq ... > $out` in the old Makefile could do.
    tmp = path + ".new"
    with open(tmp, "w") as fh:
        fh.write(text)
    os.replace(tmp, path)


def main():
    ap = argparse.ArgumentParser(prog="agents-modes-gen")
    ap.add_argument("command", choices=["claude-settings", "claude-mcp-config",
                                        "codex-profile", "codex-session-config", "manifest",
                                        "codex-rules", "container-policy-sh", "prompt",
                                        "mode-list", "runtime-helper-list",
                                        "codex-run-as-user-source",
                                        "readme-block", "readme-extract", "agent-cases-sh",
                                        "seatbelt-cases-sh", "approval-cases-sh",
                                        "witness-cases-sh", "behavior-matrix-json",
                                        "approval-witness-matrix-json", "conformance-matrix-json",
                                        "lint"])
    ap.add_argument("mode", nargs="?")
    ap.add_argument("file", nargs="?")
    ap.add_argument("--output")
    ap.add_argument("--root", default=os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
    args = ap.parse_args()

    spec = load_spec(args.root)
    if args.command == "lint":
        return lint(args.root, spec)
    lint(args.root, spec)
    if args.command == "mode-list":
        write_out(" ".join(spec["modes"]) + "\n", args.output)
        return 0
    if args.command == "runtime-helper-list":
        write_out(runtime_helper_list(spec), args.output)
        return 0
    if args.command == "codex-run-as-user-source":
        write_out(codex_run_as_user_source(spec), args.output)
        return 0
    if args.command == "codex-rules":
        write_out(codex_rules(spec), args.output)
        return 0
    if args.command == "container-policy-sh":
        write_out(container_policy_sh(spec), args.output)
        return 0
    if args.command == "agent-cases-sh":
        write_out(agent_cases_sh(spec), args.output)
        return 0
    if args.command == "seatbelt-cases-sh":
        write_out(seatbelt_cases_sh(spec), args.output)
        return 0
    if args.command == "witness-cases-sh":
        write_out(witness_cases_sh(spec), args.output)
        return 0
    if args.command == "approval-cases-sh":
        write_out(approval_cases_sh(spec), args.output)
        return 0
    if args.command == "behavior-matrix-json":
        write_out(json.dumps(behavior_matrix(spec), indent=2) + "\n", args.output)
        return 0
    if args.command == "approval-witness-matrix-json":
        write_out(json.dumps(approval_witness_matrix(spec), indent=2) + "\n", args.output)
        return 0
    if args.command == "conformance-matrix-json":
        write_out(json.dumps(conformance_matrix(spec), indent=2) + "\n", args.output)
        return 0
    if not args.mode:
        die(f"{args.command} needs an argument")

    if args.command == "readme-block":
        if args.mode not in README_BLOCKS:
            die(f"unknown README block: {args.mode} (have: {', '.join(README_BLOCKS)})")
        write_out(README_BLOCKS[args.mode](spec), args.output)
        return 0
    if args.command == "readme-extract":
        if not args.file:
            die("readme-extract needs a block name and a file")
        write_out(readme_extract(args.mode, args.file), args.output)
        return 0
    if args.command == "prompt":
        if not args.file:
            die("prompt needs a target and mode")
        write_out(prompt_text(args.root, spec, args.mode, args.file), args.output)
        return 0

    if args.command == "claude-settings":
        text = json.dumps(claude_settings(spec, args.mode), indent=2) + "\n"
    elif args.command == "claude-mcp-config":
        text = json.dumps(claude_mcp_config(spec, args.mode), indent=2) + "\n"
    elif args.command == "codex-session-config":
        text = codex_session_config(spec, args.mode)
    elif args.command == "manifest":
        text = json.dumps(manifest(spec, args.mode), indent=2) + "\n"
    else:
        frag_path = os.path.join(args.root, "codex", "tui.config.toml")
        try:
            with open(frag_path) as fh:
                fragment = fh.read()
        except OSError as exc:
            die(f"cannot read {frag_path}: {exc}")
        text = codex_profile(spec, args.mode, fragment)
    write_out(text, args.output)
    return 0


if __name__ == "__main__":
    sys.exit(main())
