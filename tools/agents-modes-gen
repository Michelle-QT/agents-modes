            add(target, mode, "secrets", "home-shell", "credential-read", "agent", "blocked-or-prompted",
                "a synthetic home credential is unreadable through the mode's shell path")
            add(target, mode, "secrets", "in-tree-shell", "in-tree-secret-shell", "agent", "blocked-or-prompted",
                "an in-tree .env is unreadable through the mode's shell path")
            if target == "claude":
                add(target, mode, "secrets", "home-tool", "credential-read-tool", "agent", "blocked-or-prompted",
