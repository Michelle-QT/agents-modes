def sh_call(name, *args):
    return " ".join([name] + [shell_word(str(a)) for a in args])


def runner_for(target):
    return f"run_{target}_agent"


def marker(target, mode, case):
    return f"agent-{target}-{mode}-{case}.txt"


def command_boundary_case(spec, mode):
    """The representative `outside -> prompt` command case for a mode."""
    m = mode_of(spec, mode)
    return "host-shell" if not m["commands"]["sandboxed_auto"] else "outside-write"


def command_positive_case(spec, mode):
    """A representative no-ask command case for a mode."""
    return "positive"


COVERAGE_AXES = ("read", "write", "egress", "secrets", "forbidden", "mcp",
                 "integrations", "commands")
COVERAGE_RUNNERS = ("offline", "seatbelt", "container", "agent", "manual", "gap")
COVERAGE_OUTCOMES = ("runs", "blocked-or-prompted", "asserted", "gap")


def _row(target, mode, axis, behavior, case, runner, outcome, note):
    return {"target": target, "mode": mode, "axis": axis, "behavior": behavior,
            "case": case, "runner": runner, "outcome": outcome, "note": note}


def behavior_matrix(spec):
    """One row per witness of a table cell: what covers it, in which tier, with what outcome.

    Runners: `offline` (test-table asserts the installed artifact), `seatbelt`
    (live-codex-sandbox runs the command in Codex's real sandbox), `container`
    (live-docker runs it inside the Research box), `agent` (agent-modes starts a real
    session), `manual` (the approval witness matrix owns it), `gap` (recorded in
    modes.json, delivered nowhere). Lint requires every target x mode x axis to have at
    least one row, so an unwitnessed cell fails `make test` instead of being invisible.

    The matrix may say a command runs no-ask, did not achieve its effect, or is a gap.
    It must not claim to distinguish user denial from auto-denial; the manual approval
    witness matrix below owns that distinction.
    """
    rows = []

    def add(*args):
        rows.append(_row(*args))

    for mode, m in spec["modes"].items():
        auto = m["commands"]["sandboxed_auto"]
        dest = m["egress"]["destinations"]
        for target in ("claude", "codex"):
            # commands
            add(target, mode, "commands", "no-ask", command_positive_case(spec, mode),
                "agent", "runs", "representative command inside the mode's no-ask region")
            boundary = command_boundary_case(spec, mode)
            if target == "codex" and not auto:
                add(target, mode, "commands", "outside", boundary, "manual", "blocked-or-prompted",
                    "codex exec is non-interactive for this prompt surface; the manual approval witness matrix owns it")
            else:
                add(target, mode, "commands", "outside", boundary, "agent", "blocked-or-prompted",
                    "non-interactive run can verify that the forbidden effect did not happen")
            subagent_case = "subagent-runbox" if not auto else "subagent-shell"
            add(target, mode, "commands", "subagent", subagent_case, "agent", "runs",
                "a subagent session uses the same no-ask shell path as the top-level agent")
            if not auto:
                add(target, mode, "commands", "host-docker", "host-docker", "agent", "blocked-or-prompted",
                    "plain docker stays gated; only runbox reaches the session box")
            if dest == "named":
                add(target, mode, "commands", "cross-mode-helper", "runbox", "agent", "blocked-or-prompted",
                    "another mode's boxed helper is refused by its own guard")
            if "sandbox-escape" in m["commands"]["grants"]:
                escape_case = "positive" if dest == "none" else "sandbox-escape"
                add(target, mode, "commands", "project-escape", escape_case, "agent", "runs",
                    "a project escape runs unsandboxed without asking")

            # read
            if m["read"]["region"] == "host":
                add(target, mode, "read", "outside-read", "filesystem", "agent", "runs",
                    "reads a file outside the workspace through the mode's shell path")
                add(target, mode, "read", "carrier", "read-carrier", "offline", "asserted",
                    "bare Read allow / ':root' asserted against the installed artifacts")
                if target == "codex":
                    add(target, mode, "read", "home-read", "seatbelt-home-read", "seatbelt", "runs",
                        "a non-secret home file is readable inside the real seatbelt")
            else:
                add(target, mode, "read", "carrier", "read-carrier", "offline", "asserted",
                    "no bare Read allow / ':minimal', plus denyRead ~/ with allowRead ./, asserted")
                if target == "claude":
                    add(target, mode, "read", "outside-read", "outside-read-tool", "agent", "blocked-or-prompted",
                        "the built-in file tool does not read a non-secret file outside the project no-ask")
                else:
                    add(target, mode, "read", "outside-read", "seatbelt-home-read-denied", "seatbelt", "blocked-or-prompted",
                        "reading a non-secret home file is denied under ':minimal'")
            if target == "codex":
                add(target, mode, "read", "workspace-read", "seatbelt-workspace-read", "seatbelt", "runs",
                    "positive control: a non-secret workspace file is readable, so a broken profile cannot pass")
            if not auto:
                add(target, mode, "read", "container-outside", "container-outside-invisible", "container", "blocked-or-prompted",
                    "the host home tree does not exist inside the box")

            # write
            if not auto:
