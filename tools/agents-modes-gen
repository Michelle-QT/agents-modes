            if target == "codex":
                add(target, mode, "forbidden", "escape-surface-seatbelt", "seatbelt-plant-escape", "seatbelt", "blocked-or-prompted",
                    "planting a sandbox escape is denied inside the real seatbelt")
                add(target, mode, "forbidden", "box-definition-seatbelt", "seatbelt-container-write", "seatbelt", "blocked-or-prompted",
                    "rewriting the box definition is denied inside the real seatbelt")
                add(target, mode, "forbidden", "git-seatbelt", "seatbelt-git-config", "seatbelt", "blocked-or-prompted",
